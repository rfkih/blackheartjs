# Server
NODE_ENV=development
PORT=8088
LOG_LEVEL=info

# Upstream bases (override only for staging/testnet)
TOKOCRYPTO_BASE_URL=https://www.tokocrypto.com
BINANCE_BASE_URL=https://api.binance.com

# Outbound HTTP
HTTP_TIMEOUT_MS=10000
HTTP_MAX_RETRIES=2

# CORS: comma-separated origins, or "*" for any (not recommended for prod)
CORS_ORIGINS=*

# Rate limiter
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
