# Blackheart exchange gateway — systemd EnvironmentFile reference.
#
# Copy to /etc/blackheart/gateway.env on the host, mode 600, owned root:
#
#   sudo install -m 600 -o root -g root \
#     deploy/scripts/gateway.env.example /etc/blackheart/gateway.env
#   sudo $EDITOR /etc/blackheart/gateway.env
#
# Loaded by the systemd unit via EnvironmentFile=. NOT loaded by dotenv —
# in production NODE_ENV=production, but the gateway also still calls
# `dotenv.config()` at startup (src/config/env.js:1). Dotenv silently
# no-ops if there is no .env in WorkingDirectory, which is the intended
# behavior here: systemd provides the values, dotenv is a dev-only convenience.
#
# Schema source of truth: src/config/env.js. If you add a key here that
# the Zod schema does not know about, it will be ignored (Zod strips unknowns).
# If you forget a required key, the process refuses to boot with a clear error.

# ── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8088
# Production logs: info or warn. `debug`/`trace` will flood journald and
# may include request bodies — only enable for short live debugging windows.
LOG_LEVEL=info

# ── Upstream exchanges ───────────────────────────────────────────────────
# Defaults point at production endpoints. Override here when bringing the
# host up against testnet first (see .env.testnet in the repo root for the
# values used during dev rehearsals).
TOKOCRYPTO_BASE_URL=https://www.tokocrypto.com
BINANCE_BASE_URL=https://api.binance.com

# ── Outbound HTTP behavior ───────────────────────────────────────────────
# Timeout per upstream call. Binance occasionally takes 6-8s under stress;
# 10s is a safe ceiling without masking real outages.
HTTP_TIMEOUT_MS=10000
# Retries are exponential-backoff via axios-retry. Cap at 2 — beyond that,
# the client (trading JVM) should decide whether to give up or retry itself,
# rather than blocking inside the gateway.
HTTP_MAX_RETRIES=2

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated origin list. "*" works for dev/testnet but MUST be narrowed
# in prod — the gateway proxies signed exchange traffic; open CORS turns it
# into a confused-deputy for anyone who can reach it.
#
# Example prod values (uncomment and edit to match your frontend origin):
# CORS_ORIGINS=https://app.blackheart.example,https://admin.blackheart.example
CORS_ORIGINS=https://app.blackheart.example

# ── Rate limiting (express-rate-limit) ───────────────────────────────────
# Per-IP. Defaults are conservative — bump RATE_LIMIT_MAX if the trading JVM
# itself starts hitting 429s under normal operation (check journald for the
# rate-limit log lines before raising).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
